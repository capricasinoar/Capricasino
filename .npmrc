# node-linker=hoisted: node_modules plano (como npm) en vez del layout aislado
# de pnpm con symlinks. Necesario para que la imagen Docker sea portable: al
# copiar node_modules a la imagen runtime, TODAS las dependencias (incluidas las
# de apps/api: reflect-metadata, argon2, @nestjs/*) quedan resolubles.
node-linker=hoisted
