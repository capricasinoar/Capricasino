# Plantilla de variables para PRODUCCIÓN. NO commitear el .env real.
# Genera cada secreto con: openssl rand -hex 32   (el arranque aborta con los de dev)

# ── API ──
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=
ADMIN_JWT_SECRET=
ADMIN_TOTP_KEY=
PROVIDER_SIM_SECRET=
PROVIDER_SIM_URL=https://provider-sim.tu-host.app
WEB_ORIGIN=https://tu-web.vercel.app
ADMIN_ORIGIN=https://tu-admin.vercel.app
PORT=4000

# ── provider-sim ──
SIM_PORT=4100
SIM_PUBLIC_URL=https://provider-sim.tu-host.app
OPERATOR_CALLBACK_URL=https://api.tu-host.app/provider/v1/callback

