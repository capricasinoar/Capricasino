{
  "name": "capri-casino",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "web": "pnpm --filter @capri/web dev",
    "api": "pnpm --filter @capri/api dev",
