# Copiar a .env — NUNCA commitear .env (regla 7 de CLAUDE.md)
DATABASE_URL=postgresql://capri:capri_dev@localhost:5432/capri_casino
REDIS_URL=redis://localhost:6379
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
WEB_ORIGIN=http://localhost:3000

# Proveedor simulado (Semana 3). El secret es COMPARTIDO operador↔proveedor.
PROVIDER_SIM_URL=http://localhost:4100
PROVIDER_SIM_SECRET=capri-sim-secret-dev
SIM_PORT=4100
SIM_PUBLIC_URL=http://localhost:4000
OPERATOR_CALLBACK_URL=http://localhost:4000/provider/v1/callback
# Modo caos del provider-sim: probabilidad de duplicar cada callback (0..1)
CHAOS_DUPLICATE_PROB=0

# Operador (para la CLI de cargas/retiradas)
ADMIN_EMAIL=owner@capri.local
ADMIN_JWT_SECRET=capri-admin-secret-dev
ADMIN_ORIGIN=http://localhost:3001
ADMIN_TOTP_KEY=capri-dev-totp-key-cambiar
